{
  "fields": [
    { "path": "full_name",     "type": "string",   "required": true  },
    { "path": "primary_email", "from": "emails[0]","type": "string",   "required": true  },
    { "path": "phone",         "from": "phones[0]","type": "string",   "required": false, "normalize": "E164"      },
    { "path": "skills",        "from": "skills[].name", "type": "string[]", "required": false, "normalize": "canonical" },
    { "path": "headline",      "type": "string",   "required": false },
    { "path": "location",      "type": "object",   "required": false },
    { "path": "experience",    "type": "string[]", "required": false },
    { "path": "education",     "type": "string[]", "required": false }
  ],
  "include_confidence": true,
  "on_missing": "null"
}